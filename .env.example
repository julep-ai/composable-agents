# Julep V2 Environment Variables
# Copy to .env and update values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/julep
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Authentication
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# PostgreSQL Extensions
POSTGRES_EXTENSIONS=pgvector,pgmq,pgai,pg_jsonschema

# Hasura
HASURA_GRAPHQL_ENDPOINT=http://localhost:8080
HASURA_ADMIN_SECRET=your-hasura-secret

# DBOS
DBOS_API_KEY=your-dbos-key
DBOS_ENVIRONMENT=development

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Memory System
MEMORY_CONSOLIDATION_INTERVAL=3600
MEMORY_DECAY_FACTOR=0.99
VECTOR_DIMENSION=1536

