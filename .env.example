# AIDEV-NOTE: env-example; template for required environment variables
# Copy this file to .env and fill in the required values

# ============================================
# Required Variables (no defaults)
# ============================================

# PostgreSQL Configuration
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Hasura Configuration
HASURA_ADMIN_SECRET=

# Application Security
APP_SECRET_KEY=
JWT_SECRET=

# LLM API Keys
OPENAI_API_KEY=

# Grafana Admin Password (if using monitoring profile)
GRAFANA_ADMIN_PASSWORD=

# ============================================
# Optional Variables (have defaults)
# ============================================

# PostgreSQL Performance Tuning
POSTGRES_PORT=5432
POSTGRES_SHARED_BUFFERS=4GB
POSTGRES_EFFECTIVE_CACHE_SIZE=12GB
POSTGRES_MAINTENANCE_WORK_MEM=2GB
POSTGRES_MAX_PARALLEL_WORKERS=4
POSTGRES_MAX_CONNECTIONS=200
POSTGRES_LOG_STATEMENT=all
POSTGRES_LOG_DURATION=on
POSTGRES_SHM_SIZE=2gb

# Hasura Configuration
HASURA_PORT=8080
HASURA_ENABLE_CONSOLE=true
HASURA_DEV_MODE=true
HASURA_UNAUTHORIZED_ROLE=anonymous
# HASURA_JWT_SECRET={"type":"HS256","key":"your-jwt-secret-key"}

# Application Configuration
APP_PORT=8000
APP_ENV=development
JWT_ALGORITHM=HS256

# Optional LLM API Keys
ANTHROPIC_API_KEY=

# Redis Configuration (optional, for caching)
REDIS_URL=redis://redis:6379
REDIS_PORT=6379

# Monitoring Configuration (optional)
ENABLE_METRICS=true
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# ============================================
# Docker Compose Profiles
# ============================================
# To run with all services: docker-compose --profile full --profile monitoring up
# - Default: postgres, hasura, app
# - full: adds redis
# - monitoring: adds prometheus, grafana